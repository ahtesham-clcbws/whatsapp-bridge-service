# WhatsApp Bridge Service - Example Configuration
# ---------------------------------------------

# PORT: The port the API server will listen on.
PORT=3001

# API_KEY: Your secure static key for all API requests. 
# Keep this private and never expose it in client-side code.
API_KEY=your_secret_api_key_here

# MAX_FILE_SIZE: Maximum allowed attachment size in bytes (e.g., 50MB).
MAX_FILE_SIZE=52428800

# WHATSAPP_AUTH_DIR: Directory to store persistent WhatsApp session data.
WHATSAPP_AUTH_DIR=./auth
